---
interface Props {
  title?: string;
}

const { title = "PARA Life" } = Astro.props;
---

<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="stylesheet" href="/styles/global.css" />
  </head>
  <body>
    <header>
      <nav>
        <a href="/" class="logo">PARA Life</a>
        <div class="nav-links">
          <a href="/#projects">Projects</a>
          <a href="/#areas">Areas</a>
          <a href="/#resources">Resources</a>
          <a href="/#archives">Archives</a>
        </div>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <p>PARA Life Management System</p>
    </footer>
  </body>
</html>

<style>
  header {
    border-bottom: 1px solid var(--border);
    padding: 1rem 2rem;
  }

  nav {
    max-width: 960px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--text);
  }

  .logo:hover {
    text-decoration: none;
    color: var(--accent);
  }

  .nav-links {
    display: flex;
    gap: 1.5rem;
    font-size: 0.9rem;
  }

  .nav-links a {
    color: var(--text-muted);
  }

  .nav-links a:hover {
    color: var(--text);
    text-decoration: none;
  }

  main {
    max-width: 960px;
    margin: 0 auto;
    padding: 2rem;
  }

  footer {
    border-top: 1px solid var(--border);
    padding: 2rem;
    text-align: center;
    color: var(--text-muted);
    font-size: 0.8rem;
    margin-top: 4rem;
  }
</style>

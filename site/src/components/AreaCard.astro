---
interface Props {
  area: any;
}

const { area } = Astro.props;
const isLimited = area.visibility === "limited";
---

{isLimited ? (
  <a href={`/me/areas/${area.id}`} class="card limited">
    <h3>{area.title}</h3>
    <span class="lock">Limited</span>
  </a>
) : (
  <a href={`/areas/${area.id}`} class="card">
    <h3>{area.title}</h3>
    {area.description && <p class="desc">{area.description}</p>}
    {area.tags?.length > 0 && (
      <div class="tags">
        {area.tags.map((tag: string) => <span class="tag">#{tag}</span>)}
      </div>
    )}
  </a>
)}

<style>
  .card {
    display: block;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.2rem;
    transition: border-color 0.2s;
    color: var(--text);
  }

  .card:hover {
    border-color: var(--purple);
    text-decoration: none;
  }

  .card.limited {
    opacity: 0.7;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .card.limited:hover {
    border-color: var(--purple);
    opacity: 0.85;
  }

  .lock {
    font-size: 0.7rem;
    color: var(--text-muted);
    border: 1px solid var(--border);
    padding: 0.1rem 0.4rem;
    border-radius: 3px;
    text-transform: uppercase;
  }

  h3 {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.4rem;
  }

  .desc {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-bottom: 0.6rem;
  }

  .tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .tag {
    font-size: 0.75rem;
    color: var(--purple);
  }
</style>
